{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/yoga-wasm-web/dist/**/*.wasm"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "api/index.ts" }]
}
